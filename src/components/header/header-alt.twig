<header class="header-alt">
  <div class="headerTop">
    <div class="container">
      <div class="headerTop__inner">
        <div class="header-tabs">
          <a href="#" class="header-tabs__link">Hokejbal.sk</a>
          <a href="#" class="header-tabs__link active">Shbu.sk</a>
        </div>
        <a href="#" class="header-sponsor">
          <img src="images/ico/lasvit.svg" alt="" />
        </a>
        <form class="search">
          <button>
            <img src="images/ico/search.svg" alt="search button" />
          </button>
          <input placeholder="Čo hledáte?" type="text" name="headerSearch" />
        </form>
        {% include "@components/social/social.twig" %}
