              <li class="nav-item">
                <a class="nav-link" href="#">Zápisnice a rozhodnutia</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#">Komise a orgány SHbÚ</a>
              </li>
              <li class="nav-item">
                <a class="nav-link" href="#">Kontakt na sekretariát</a>
              </li>
            </ul>
          </div>
          <div class="d-lg-none d-flex mt-8 justify-content-center">
            {% include "@components/social/social.twig" %}
          </div>
        </nav>

        <button class="c-header__opener js-header__opener" type="button">
          <span></span>
        </button>
