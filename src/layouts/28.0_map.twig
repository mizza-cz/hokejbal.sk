                  <div class="text-xl-semibold font-title">
                    HC Slovan Bratislava
                  </div>
                  <p class="text-sm-medium text-secondary">
                    Odbojárov 9, 831 04, Bratislava
                  </p>
                </div>
              </div>
              <img
                class="mapItem__icon"
                src="images/ico/chevron-down.svg"
                loading="lazy"
                alt="arrow"
              />
            </div>
            <div
              class="d-flex align-items-center gap-2 text-xxs-bold text-secondary mt-3"
