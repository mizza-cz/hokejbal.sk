{% extends "@components/base/base.twig" %} {% set use_alt_header = true %} {%
set title = "28.0_map" %} {% block main %}

<div class="mb-lg-20 mb-10">
  <div class="container">
    <div class="headerPage">
      <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
          <li class="breadcrumb-item">
            <a href="#">Home</a>
          </li>
          <li class="breadcrumb-item active" aria-current="page">Mapa klubu</li>
        </ol>
      </nav>

      <h1 class="h2 titleDot text-center">Mapa klubu</h1>
    </div>
    <div class="container-sm p-0">
      <form class="search mt-6 mb-4">
        <button>
          <img src="images/ico/search-secondary.svg" alt="search button" />
        </button>
        <input
          id="search-input"
          class="bg-secondary border-inverse text-secondary"
          placeholder="Čo hledáte?"
          type="text"
          name="search"
        />
      </form>
      <div class="search__location">
        <button id="find-me" type="button">
          {% include "@images/cursor.svg" %} Použít aktuální polohu
        </button>
        <p id="status"></p>
        <a id="map-link" target="_blank"></a>
      </div>
    </div>
    <div class="d-flex mb-4 border-bottom overflow-scroll slim-scroll pb-0">
      <a
        class="text-accent border-bottom border-3 border-primary font-title text-lg-semibold font-italic px-lg-6 px-4 py-lg-4 py-3 hover-outline d-block"
        href="#"
      >
        Muži
      </a>

      <a
        class="font-title text-lg-semibold font-italic px-lg-6 px-4 py-lg-4 py-3 hover-outline d-block"
        href="#"
      >
        Mládež
      </a>
      <a
        class="font-title text-lg-semibold font-italic px-lg-6 px-4 py-lg-4 py-3 hover-outline d-block"
        href="#"
      >
        Městské ligy
      </a>
    </div>
